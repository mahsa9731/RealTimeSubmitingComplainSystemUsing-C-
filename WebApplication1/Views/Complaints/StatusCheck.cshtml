@model IEnumerable<WebApplication1.Models.ComplaintModel>
@using WebApplication1.Helpers;
@{
    ViewData["Title"] = "StatusCheck";
}

<h1>پیگیری شکایات</h1>

<div class="container mt-5">
    <h3>لیست شکایات ثبت شده شما</h3>
    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>کد رهگیری</th>
                <th>عنوان شکایت</th>
                <th>تاریخ ثبت</th>
                <th>وضعیت بررسی</th>
                <th>جزئیات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var complaint in Model)
            {
                <tr>
                    <td>@complaint.TrackingCode</td>
                    <td>@complaint.TitleOfComplaint</td>
                    <td>@complaint.DateOfCreateComplaint.ToString("yyyy/MM/dd")</td>
                    <td>
                        <span class="badge bg-info text-dark">
                            <a>@complaint.Status.GetDisplayName()</a>
                        </span>
                    </td>
                    <td>
                        <a asp-action="DetailsForRegisteredComplaint" asp-route-id="@complaint.ComplaintId" class="btn btn-primary btn-sm">
                            مشاهده
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

