@using Microsoft.AspNetCore.Identity;
@model WebApplication1.Models.ComplaintModel

@{
    ViewData["Title"] = "ثبت شکایت جدید";
}

@inject UserManager<WebApplication1.Models.User> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var email = currentUser?.Email;
}

@Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

@if (ViewBag.ModelErrors != null)
{
    <div class="alert alert-danger">
        @foreach (var e in (IEnumerable<dynamic>)ViewBag.ModelErrors)
        {
            <div><strong>@e.Field:</strong> @string.Join(", ", e.Errors)</div>
        }
    </div>
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h4 class="mt-2">فرم ثبت شکایت</h4>
                </div>
                <div class="card-body p-4 bg-light">

                    <form asp-action="Create" method="Post">
                         @Html.AntiForgeryToken()
                        <div class="mb-3">
                           <label asp-for="UserName" class="form-label fw-bold">نام و نام خانوادگی</label>
                           <input asp-for="UserName" class="form-control" placeholder="نام و نام خانوادگی خود را وارد کنید" />
                           <span asp-validation-for="UserName" class="text-danger"></span>
                         </div>
                         <div class="mb-3">
                            <label asp-for="TitleOfComplaint" class="form-label fw-bold">عنوان شکایت</label>
                            <input asp-for="TitleOfComplaint" class="form-control" placeholder="مثلاً تاخیر در تحویل سفارش" />
                            <span asp-validation-for="TitleOfComplaint" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">متن شکایت</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="توضیحات خود را بنویسید..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PackageCode" class="form-label fw-bold">کد مرسوله</label>
                            <input asp-for="PackageCode" class="form-control" placeholder="کد مرسوله را وارد کنید" />
                            <span asp-validation-for="PackageCode" class="text-danger"></span>
                         </div>


                        <div class="mb-3">
                            <label class="form-label fw-bold">ایمیل شما</label>
                            <input type="email" class="form-control" value="@email" readonly />
                        </div class="form-group">

                        <input type="submit" value="ارسال شکایت" class="btn btn-success w-100 py-2 rounded-3 fw-bold"/>  
                        
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}