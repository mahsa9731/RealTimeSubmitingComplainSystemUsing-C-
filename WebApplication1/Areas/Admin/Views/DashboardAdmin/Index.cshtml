@model IEnumerable<WebApplication1.Models.ComplaintModel>
@using WebApplication1.Models
@using WebApplication1.Helpers;
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml"; //ino bayad bezariiiiii.
}
@{
    ViewData["Title"] = "پنل مدیریت شکایات";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white rounded-top-4">
            <h4 class="mb-0"><i class="bi bi-speedometer2"></i> پنل مدیریت شکایات</h4>
        </div>

        <div class="card-body p-4 bg-light">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>کد رهگیری</th>
                            <th>عنوان</th>
                            <th>نام کاربر</th>
                            <th>تاریخ ثبت</th>
                            <th>کد مرسوله</th>
                            <th> وضعیت</th> 
                            <th class="text-center">جزئیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@item.TrackingCode</span></td>
                                <td>@item.TitleOfComplaint</td>
                                <td>@item.UserName</td>
                                <td>@item.DateOfCreateComplaint.ToString("yyyy/MM/dd HH:mm")</td>
                                <td>@item.PackageCode</td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        <a>@item.Status.GetDisplayName()</a>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="/Admin/DashboardAdmin/DetailsForAdmin/@item.ComplaintId"
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        مشاهده جزئیات
                                    </a>


                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted text-center">هیچ شکایتی برای نمایش وجود ندارد.</p>
            }

            <form action="/Home/Index" method="post" class="d-inline">
                <button type="submit" class="btn btn-danger fw-bold px-4 py-2 rounded shadow-sm">
                     خروج
                </button>
            </form>

    </div>
</div>
