@model WebApplication1.Models.ComplaintModel

@using WebApplication1.Helpers
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "بررسی جزئیات شکایت ثبت‌شده";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h4 class="mb-0"><i class="bi bi-info-circle"></i> جزئیات شکایت</h4>
        </div>

        <div class="card-body p-4 bg-light">

            
            <div class="mb-3"><label class="fw-semibold">کد رهگیری شکایت:</label> <span class="badge bg-secondary">@Model.TrackingCode</span></div>
            <div class="mb-3"><label class="fw-semibold">کد بسته:</label> <span>@Model.PackageCode</span></div>
            <div class="mb-3"><label class="fw-semibold">عنوان:</label> <span>@Model.TitleOfComplaint</span></div>
            <div class="mb-3"><label class="fw-semibold">توضیحات:</label> <p class="bg-white p-3" style="white-space:pre-wrap;">@Model.Description</p></div>
            <div class="mb-3"><label class="fw-semibold">تاریخ ثبت:</label> <span>@Model.DateOfCreateComplaint.ToString("yyyy/MM/dd HH:mm")</span></div>

            <hr />

           
            <h5 class="fw-semibold">گفتگو</h5>
            <div id="messagesContainer">
                @if (Model.Messages != null && Model.Messages.Any())
                {
                    foreach (var msg in Model.Messages.OrderBy(m => m.SentAtDate))
                    {
                        <div class="alert @(msg.isFromAdmin ? "alert-warning" : "alert-secondary") rounded-3 shadow-sm">
                            <div class="d-flex justify-content-between">
                                <strong>@(msg.isFromAdmin ? "ادمین" : "کاربر")</strong>
                                <small>@msg.SentAtDate.ToString("yyyy/MM/dd HH:mm")</small>
                            </div>
                            <div class="mt-2">@msg.Message</div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">هنوز پیامی وجود ندارد.</p>
                }
            </div>

            <hr />

           
            <form id="sendMessageForm">
                <input type="hidden" id="complaintId" value="@Model.ComplaintId" />
                <textarea id="MessageContent" class="form-control" rows="3" placeholder="پیام خود را بنویسید..."></textarea>
                <button type="submit" class="btn btn-primary mt-2">
                    <i class="bi bi-send"></i> ارسال پیام
                </button>
            </form>

            <textarea id="finalMessage" class="form-control mt-2" rows="3" placeholder="ارسال پاسخ نهایی به کاربر و بسته شدن شکایت..."></textarea>
            <button type="button" class="btn btn-success mt-2" onclick="closeComplaint(@Model.ComplaintId)">
                <i class="bi bi-check-circle"></i> بستن شکایت
            </button>

            <div class="mt-4 text-end">
                <a href="@Url.Action("Index", "DashboardAdmin", new { area = "Admin" })" class="btn btn-outline-secondary rounded-pill">
                    <i class="bi bi-arrow-left"></i> بازگشت به پنل ادمین
                </a>
            </div>


            <script>
                async function closeComplaint(complaintId) {
                    const content = document.getElementById("finalMessage").value.trim();
                    if (!content) {
                        alert("لطفا پیام نهایی را وارد کنید.");
                        return;
                    }

                    const token = '@Antiforgery.GetAndStoreTokens(Context).RequestToken';

                    const res = await fetch('/Admin/DashboardAdmin/CloseComplaint', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            complaintId: complaintId,
                            content: content,
                            isFromAdmin: true
                        })
                    });

                    if (res.ok) {
                        alert("شکایت با موفقیت بسته شد.");
                        location.href = '/Admin/DashboardAdmin/Index';
                    } else {
                        alert("خطا در بستن شکایت.");
                    }
                }
            </script>

        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.5/dist/browser/signalr.min.js"></script>

<script>
    const complaintId = document.getElementById("complaintId").value;
    const sender = "ادمین"; 
    
    const connection = new signalR.HubConnectionBuilder()
        .withUrl(`/complaintChatHub?complaintId=${complaintId}`)
        .build();

   
    connection.on("ReceiveMessage", (sender, message, sentAt) => {
        const container = document.getElementById("messagesContainer");
        const emptyText = container.querySelector("p.text-muted");
        if (emptyText) emptyText.remove();

        const html = `
            <div class="alert ${sender === 'ادمین' ? 'alert-warning' : 'alert-secondary'} rounded-3 shadow-sm">
                <div class="d-flex justify-content-between">
                    <strong>${sender}</strong>
                    <small>${sentAt}</small>
                </div>
                <div class="mt-2">${message}</div>
            </div>
        `;
        container.insertAdjacentHTML("beforeend", html);
        container.scrollTop = container.scrollHeight;
    });

    connection.start().catch(err => console.error(err));

    // Sending New Message
    document.getElementById("sendMessageForm").addEventListener("submit", async function (e) {
        e.preventDefault();
        const message = document.getElementById("MessageContent").value.trim();
        if (!message) return;

        const res = await fetch('/Admin/DashboardAdmin/SaveMessage', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': '@token'
            },
            body: JSON.stringify({
                complaintId: complaintId,
                content: message,
                isFromAdmin: true
            })
        });

        if (res.ok) {
            await connection.invoke("SendMessage", complaintId, sender, message);
            document.getElementById("MessageContent").value = '';
        } else {
            alert("ارسال پیام با خطا مواجه شد.");
        }
    });
</script>
