@model WebApplication1.Areas.Admin.Models.AdminLoginViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "ورود ادمین";
}

<div class="container" dir="rtl">
    <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header text-center bg-primary text-white rounded-top-4">
                    <h3 class="mb-0">ورود به پنل ادمین</h3>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center">@ViewBag.Error</div>
                    }

                    <form asp-area="Admin" asp-controller="AccountAdmin" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">ایمیل</label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="example@domain.com" autocomplete="username" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold">رمز عبور</label>
                            <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="رمز عبور را وارد کنید" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-semibold shadow-sm">
                            ورود
                        </button>
                    </form>
                </div>
                <div class="card-footer text-center text-muted">
                    © 2025 پنل مدیریت
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
